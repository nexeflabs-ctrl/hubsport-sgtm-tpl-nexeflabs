___SANDBOXED_JS_FOR_SERVER___

const claimRequest = require('claimRequest');
const getRequestPath = require('getRequestPath');
const getRequestBody = require('getRequestBody');
const sendHttpGet = require('sendHttpGet');
const runContainer = require('runContainer');
const returnResponse = require('returnResponse');
const setResponseStatus = require('setResponseStatus');
const setResponseBody = require('setResponseBody');
const logToConsole = require('logToConsole');
const JSON = require('JSON');


const HUBSPOT_PATH = data.path;
const EVENT_NAME = data.eventName;
const HUBSPOT_TOKEN = data.accessToken;

function handleRequest() {
  var requestURL = 'https://api.hubapi.com/crm/v3/objects/contacts/';
  var path = getRequestPath();

  if (path !== HUBSPOT_PATH) {
    return;
  }

  claimRequest();

  var body = getRequestBody();
  if (!body) {
    setResponseStatus(400);
    returnResponse();
    return;
  }

  var events;

    events = JSON.parse(body);

  if (!events || !events.length) {
    setResponseStatus(400);
    returnResponse();
    return;
  }
setResponseBody('Ok');
returnResponse();
 
for (var i = 0; i < events.length; i++) {
 var evt = events[i];
 var contactId = evt.objectId;
 var LeadStatus = evt.propertyValue;

 if (!contactId) {
   logToConsole('No contactId found at index ' + i);
   continue;
 }

if(data.contactProperties){
var props = [];
data.contactProperties.forEach((d) => props.push(d.properties));
  
requestURL = 'https://api.hubapi.com/crm/v3/objects/contacts/' + contactId+'?properties='+ props.join(',');
}else{
requestURL = requestURL + contactId;
}

    var hubspotResponse = sendHttpGet(requestURL ,{
     headers: {
         Authorization: 'Bearer ' + HUBSPOT_TOKEN,
        'Content-Type': 'application/json'
      }
    }
    ).then((result) => {
   var contactData = JSON.parse(result.body);
   logToConsole(contactData);
    var props = contactData.properties || {};

   
    runContainer({
      event_name: EVENT_NAME,
      contactId: contactId,
      lead_status: LeadStatus,
      properties : props
    });
  returnResponse();
    
    });
   
  }
}

handleRequest();


